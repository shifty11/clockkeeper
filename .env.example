# =============================================================================
# Server
# =============================================================================
WEB_LISTEN=:8080
LOG_LEVEL=info          # debug, info, warn, error
LOG_FORMAT=text         # text, json

# =============================================================================
# Authentication
# =============================================================================
JWT_SECRET_KEY=
# JWT_SECRET_KEY_FILE=/run/secrets/jwt_secret_key

# =============================================================================
# Discord OAuth (create app at https://discord.com/developers/applications)
# =============================================================================
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# DISCORD_CLIENT_SECRET_FILE=/run/secrets/discord_client_secret
# DISCORD_REDIRECT_URI=      # optional override, frontend constructs default

# =============================================================================
# Rate Limiting (requests per minute)
# =============================================================================
# RATE_LIMIT_ANON=120
# RATE_LIMIT_AUTH=120

# =============================================================================
# Anonymous User Cleanup
# =============================================================================
# ANONYMOUS_MAX_AGE=8760h    # 365 days

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clockkeeper
DB_USER=postgres
DB_PASSWORD=postgres
# DB_PASSWORD_FILE=/run/secrets/db_password
