# =============================================================================
# Server
# =============================================================================
WEB_LISTEN=:8080
LOG_LEVEL=info          # debug, info, warn, error
LOG_FORMAT=text         # text, json

# =============================================================================
# Authentication
# =============================================================================
JWT_SECRET_KEY=
# JWT_SECRET_KEY_FILE=/run/secrets/jwt_secret_key
# Create users with: clockkeeper create-user <username> <password>

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clockkeeper
DB_USER=postgres
DB_PASSWORD=postgres
# DB_PASSWORD_FILE=/run/secrets/db_password
